# Keep these essential files
!README.md
!LICENSE
!CONTRIBUTING.md
!CHANGELOG.md
!ROADMAP.md
!.gitignore
!.github/workflows/*.yml
!requirements.txt
!package.json
!pyproject.toml
!setup.py
!setup.cfg
!Dockerfile
!docker-compose.yml
!contextflow/
!contextflow/**/*.py
!contextflow/tests/test_compression.py
!contextflow/tests/test_comprehensive.py
!contextflow/tests/test_advanced.py